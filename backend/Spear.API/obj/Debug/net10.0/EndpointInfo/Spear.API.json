      "LeaderboardEntryDto": {
        "type": "object",
        "properties": {
          "rank": {
            "type": "integer",
            "format": "int32"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "totalProfit": {
            "type": "number",
            "format": "double"
          },
          "totalBets": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
