      },
      "BetResultDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "roundId": {
            "type": "string",
            "format": "uuid"
          },
          "roundNumber": {
            "type": "integer",
            "format": "int64"
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "autoCashoutAt": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "cashedOutAt": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "crashPoint": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "profit": {
            "type": "number",
            "format": "double"
          },
          "won": {
            "type": "boolean"
          },
          "placedAt": {
            "type": "string",
            "format": "date-time"
          },
          "roundState": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "BetResultDtoPagedResult": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BetResultDto"
            },
            "nullable": true
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "totalCount": {
            "type": "integer",
            "format": "int32"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "DepositRequest": {
        "required": [
          "amount"
        ],
        "type": "object",
        "properties": {
          "amount": {
            "maximum": 1000000,
            "minimum": 1,
            "type": "number",
            "format": "double"
          },
          "method": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GameHistoryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "roundNumber": {
            "type": "integer",
            "format": "int64"
          },
          "crashPoint": {
            "type": "number",
            "format": "double"
          },
          "endedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
