  "components": {
    "schemas": {
      "ActiveBetDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "roundId": {
            "type": "string",
            "format": "uuid"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "autoCashoutAt": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "placedAt": {
            "type": "string",
